# ─── Copy this file to server/.env and fill in the values ───
# server/.env is gitignored. NEVER commit real keys.

# A THROWAWAY 0G testnet wallet's private key (0x...). Create a fresh wallet,
# fund it at https://faucet.0g.ai, and use it ONLY for this. Never a wallet
# that holds real funds. The proxy signs storage uploads with this.
ZG_PRIVATE_KEY=

# 0G Galileo testnet EVM RPC.
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# ─── 0G Compute (AI inference) ───
# Get an API key + deposit testnet 0G at https://pc.0g.ai
ZG_COMPUTE_API_KEY=
# OpenAI-compatible router endpoint.
ZG_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
# Model id served by 0G Compute. List the ids your key can use with:
#   GET https://router-api.0g.ai/v1/models  (Authorization: Bearer <key>)
# Known-good chat models incl: deepseek-v4-flash, deepseek-v3, glm-5, qwen3.7-plus.
ZG_COMPUTE_MODEL=deepseek-v4-flash

# ─── Saves ───
# Progress is saved on 0G Chain (the L1) as transaction calldata — uses ZG_RPC_URL
# + ZG_PRIVATE_KEY above, no extra config needed.
#
# The 0G Storage path (lib/storage.js) is parked: the published SDK
# (@0glabs/0g-ts-sdk 0.3.3) is out of sync with the current Galileo flow contract.
# This indexer endpoint is only used if you revisit that path.
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Port the proxy listens on. The client defaults to http://localhost:8787.
PORT=8787

# Comma-separated browser origins allowed to call this proxy (CORS).
# Vite dev server default is http://localhost:5173.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
